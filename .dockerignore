# Build context trimming. node_modules is reinstalled by the `deps` stage
# (npm ci) and .next is regenerated by `next build`, so shipping the local
# copies only bloats the context. .git isn't needed in the image.
#
# NOTE: .env.production / .env.local are intentionally NOT ignored — Next.js
# loads them during `next build` to inline NEXT_PUBLIC_* values into the
# client bundle. Both hold production values on this host.
node_modules
.next
.git
npm-debug.log*
*.log
.DS_Store
.claude
